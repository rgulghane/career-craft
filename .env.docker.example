# Docker / docker-compose deployment template
# ---------------------------------------------------------------------------
# 1. Copy:  cp .env.docker.example .env
# 2. Edit values below (never commit .env)
# 3. Run:   docker compose up --build
#
# Compose reads `.env` from the repo root for ${VAR} substitution.
# The web container receives these as runtime environment variables.
# ---------------------------------------------------------------------------

# --- Required (production) ---------------------------------------------------
NODE_ENV=production

# MongoDB — use the compose service hostname when running bundled mongo:
DATABASE_URL=mongodb://mongo:27017/career_craft
# Or Atlas / external:
# DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/career_craft?retryWrites=true&w=majority

# 32+ character random strings (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-in-production-min-32-chars-long!!
CRON_SECRET=change-me-cron-internal

# Public URL of the app (no trailing slash) — used for referral links & OAuth redirects
APP_ORIGIN=http://localhost:3000

# --- Database startup (optional; useful for cold starts / Atlas) ------------
# DB_CONNECT_MAX_ATTEMPTS=30
# DB_CONNECT_DELAY_MS=2000
# If Atlas still fails on a cloud host after fixing Network Access, try:
# MONGODB_FORCE_IPV4=1

# --- Google OAuth (optional) -------------------------------------------------
# Authorized redirect URI: {APP_ORIGIN}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Razorpay (required for live payments) -----------------------------------
# Test keys: https://dashboard.razorpay.com/app/keys
# Webhook URL: {APP_ORIGIN}/api/payments/razorpay/webhook
# Events: payment.captured, payment.failed, refund.created, refund.processed
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Azure Blob Storage (mentor image uploads) -------------------------------
# Option A — connection string (simplest):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# Option B — managed identity (recommended on Azure App Service / Container Apps):
#   set only the account name and grant the app "Storage Blob Data Contributor".
# AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
# Container that holds mentor photos (created automatically if missing):
# AZURE_STORAGE_CONTAINER_NAME=mentor-photos
# Optional CDN / Front Door public base URL (no trailing slash):
# AZURE_STORAGE_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# --- Pricing (optional; amounts in rupees) -----------------------------------
# STANDARD_PRICE=5000
# REFERRAL_PRICE=2500
# CASH_PER_REFERRAL=500
# REFUND_WINDOW_DAYS=30

# --- Container (usually leave as-is) -----------------------------------------
# PORT=3000
# HOSTNAME=0.0.0.0
