# Copy to apps/web/.env.local for development.

# --- Database ----------------------------------------------------------------
# MongoDB connection string (include database name in the path).
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/career_craft?retryWrites=true&w=majority"
# Windows: if `querySrv ECONNREFUSED` with mongodb+srv, public DNS is applied automatically.
# Other platforms: set MONGODB_USE_PUBLIC_DNS=1 (optional MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1)
# Disable override: MONGODB_DNS_OVERRIDE=0
# Startup retries if the database is not ready yet (Docker / cold start).
# DB_CONNECT_MAX_ATTEMPTS=30
# DB_CONNECT_DELAY_MS=2000

# --- Auth --------------------------------------------------------------------
# Use a 32+ char random string in production.
JWT_SECRET="change-me-in-production-min-32-chars-long!!"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {APP_ORIGIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Internal cron -----------------------------------------------------------
CRON_SECRET="change-me-cron-internal"

# --- Public origin -----------------------------------------------------------
# Canonical origin used for referral share links.
APP_ORIGIN="http://localhost:3000"

# WhatsApp floating chat (country code + number, no + or spaces)
WHATSAPP_NUMBER="919876543210"

# --- Razorpay (payments) -----------------------------------------------------
# Test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# Webhook secret from Dashboard → Webhooks (POST https://your-domain/api/payments/razorpay/webhook)
# Subscribe to: payment.captured, payment.failed, refund.created, refund.processed
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# --- Pricing (rupees; optional — defaults 5000 / 2500) ---------------------
# STANDARD_PRICE=5000
# REFERRAL_PRICE=2500
# CASH_PER_REFERRAL=500
# REFUND_WINDOW_DAYS=30
