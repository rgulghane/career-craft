# Copy to apps/web/.env.local for development.

# --- Database ----------------------------------------------------------------
# Postgres connection string. For local dev you can run docker compose up -d.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/career_craft"

# --- Auth --------------------------------------------------------------------
# Use a 32+ char random string in production.
JWT_SECRET="change-me-in-production-min-32-chars-long!!"

# --- Internal cron -----------------------------------------------------------
CRON_SECRET="change-me-cron-internal"

# --- Public origin -----------------------------------------------------------
# Canonical origin used for referral share links.
APP_ORIGIN="http://localhost:3000"

# --- Optional overrides (paise) ---------------------------------------------
# STANDARD_PRICE_PAISE=500000
# REFERRAL_PRICE_PAISE=250000
# CASH_PER_REFERRAL_PAISE=50000
# REFUND_WINDOW_DAYS=7
