{
  "name": "@career-craft/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "npm run db:env -- npx --yes tsx scripts/ensure-indexes.ts",
    "db:create-admin": "npm run db:env -- npx --yes tsx scripts/create-admin.ts",
    "db:create-admin-readonly": "npm run db:env -- npx --yes tsx scripts/create-admin-readonly.ts",
    "db:create-readonly-admins-batch": "npm run db:env -- npx --yes tsx scripts/create-readonly-admins-batch.ts",
    "db:seed-mentors": "npm run db:env -- npx --yes tsx scripts/seed-mentors.ts",
    "db:env": "dotenv -c development --"
  },
  "dependencies": {
    "@career-craft/shared": "file:../../packages/shared",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.21.0",
    "next": "^15.1.3",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
