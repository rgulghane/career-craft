{
  "name": "career-craft",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "install:all": "npm run install:shared && npm run install:web && npm install",
    "install:shared": "npm install --prefix packages/shared",
    "install:web": "npm install --prefix apps/web",
    "dev:prepare": "npm run build --prefix packages/shared && npm run db:setup",
    "dev": "npm run dev:prepare && npm run dev --prefix apps/web",
    "dev:clean": "node -e \"try{require('fs').rmSync('apps/web/.next',{recursive:true,force:true})}catch(e){}\" && npm run dev",
    "dev:shared": "npm run watch --prefix packages/shared",
    "build": "npm run build --prefix packages/shared && npm run build --prefix apps/web",
    "start": "npm run start --prefix apps/web",
    "db:setup": "npm run db:setup --prefix apps/web",
    "db:create-admin": "npm run db:create-admin --prefix apps/web",
    "db:create-admin-readonly": "npm run db:create-admin-readonly --prefix apps/web",
    "db:create-readonly-admins-batch": "npm run db:create-readonly-admins-batch --prefix apps/web",
    "lint": "npm run lint --prefix apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}
